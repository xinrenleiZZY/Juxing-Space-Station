<Window x:Class="AIChatWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AIChatWPF"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        mc:Ignorable="d"
        Title="AI智能对话" 
        Height="800" 
        Width="1000"
        Background="#1a1a2e"
        WindowStartupLocation="CenterScreen">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- 标题栏 -->
        <Border Grid.Row="0" 
                Background="#16213e" 
                Padding="20,15"
                BorderBrush="#0f3460"
                BorderThickness="0,0,0,1">
            <StackPanel>
                <TextBlock Text="AI智能对话" 
                          FontSize="24" 
                          FontWeight="Bold"
                          Foreground="#eaeaea"
                          HorizontalAlignment="Center"/>
                <TextBlock Text="基于DeepSeek API的智能助手" 
                          FontSize="12"
                          Foreground="#a0aec0"
                          HorizontalAlignment="Center"
                          Margin="0,5,0,0"/>
            </StackPanel>
        </Border>
        
        <!-- 模型选择 -->
        <Border Grid.Row="1" 
                Background="#16213e"
                Padding="20,15"
                BorderBrush="#0f3460"
                BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="选择模型：" 
                          VerticalAlignment="Center"
                          Foreground="#eaeaea"
                          FontSize="14"
                          Margin="0,0,10,0"/>
                <ComboBox x:Name="ModelComboBox"
                         Width="300"
                         Style="{StaticResource ModernComboBoxStyle}"
                         SelectedIndex="0">
                    <ComboBoxItem Content="豆包 1.5 视觉 Pro 32k" Tag="doubao-1-5-vision-pro-32k-250115"/>
                    <ComboBoxItem Content="豆包 1.5 Lite 32k" Tag="doubao-1-5-lite-32k-250115"/>
                    <ComboBoxItem Content="豆包 1.5 Pro 32k" Tag="doubao-1-5-pro-32k-250115"/>
                    <ComboBoxItem Content="豆包种子 1.8" Tag="doubao-seed-1-8-251228"/>
                    <ComboBoxItem Content="豆包种子 1.6 Lite" Tag="doubao-seed-1-6-lite-251015"/>
                    <ComboBoxItem Content="豆包种子 1.6 视觉" Tag="doubao-seed-1-6-vision-250815"/>
                    <ComboBoxItem Content="豆包种子 1.6" Tag="doubao-seed-1-6-251015"/>
                    <ComboBoxItem Content="豆包种子 1.6 Flash" Tag="doubao-seed-1-6-flash-250828"/>
                    <ComboBoxItem Content="DeepSeek V3.2" Tag="deepseek-v3-2-251201"/>
                    <ComboBoxItem Content="DeepSeek V3.1" Tag="deepseek-v3-1-terminus"/>
                    <ComboBoxItem Content="DeepSeek R1" Tag="deepseek-r1-250528"/>
                    <ComboBoxItem Content="DeepSeek V3" Tag="deepseek-v3-250324"/>
                    <ComboBoxItem Content="Kimi K2" Tag="kimi-k2-thinking-251104"/>
                    <ComboBoxItem Content="GLM 4.7" Tag="glm-4-7-251222"/>
                </ComboBox>
            </StackPanel>
        </Border>
        
        <!-- 对话内容区域 -->
        <Border Grid.Row="2" 
                Background="#1a1a2e"
                Padding="20">
            <wv2:WebView2 x:Name="ChatWebView"
                         DefaultBackgroundColor="#1a1a2e"/>
        </Border>
        
        <!-- 输入区域 -->
        <Border Grid.Row="3" 
                Background="#16213e"
                Padding="20"
                BorderBrush="#0f3460"
                BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBox x:Name="QuestionTextBox"
                        Grid.Column="0"
                        Style="{StaticResource ModernTextBoxStyle}"
                        TextWrapping="Wrap"
                        AcceptsReturn="True"
                        Height="80"
                        VerticalScrollBarVisibility="Auto"
                        VerticalContentAlignment="Top"
                        Padding="12,8"
                        FontSize="14"
                        KeyDown="QuestionTextBox_KeyDown"
                        ToolTip="按 Enter 发送，Shift+Enter 换行"/>
                
                <StackPanel Grid.Column="1" 
                           Orientation="Vertical"
                           Margin="15,0,0,0">
                    <Button x:Name="SendButton"
                           Style="{StaticResource PrimaryButtonStyle}"
                           Content="发送"
                           Height="80"
                           Width="100"
                           Click="SendButton_Click"/>
                    
                    <ProgressBar x:Name="LoadingProgressBar"
                                IsIndeterminate="True"
                                Visibility="Collapsed"
                                Height="4"
                                Margin="0,10,0,0"
                                Background="#0f3460"
                                Foreground="#667eea"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>